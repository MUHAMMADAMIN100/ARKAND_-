# --- Обязательные ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sheben_zavod?schema=public"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars!!"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars!"

# --- Опциональные ---
PORT=3001
NODE_ENV=development
# Origin фронтенда для CORS (прод: https://<project>.vercel.app)
FRONTEND_ORIGIN=http://localhost:5173
# Redis: без него кэш in-memory, очереди BullMQ отключены
# REDIS_URL=redis://localhost:6379
# Sentry (прод)
# SENTRY_DSN=
# Времена жизни токенов
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=200
